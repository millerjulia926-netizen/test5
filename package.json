{
  "name": "test5",
  "version": "0.1.0",
  "private": true,
  "description": "Notes app",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:client": "npm run dev --prefix client",
    "build": "tsc && cp -r src/migrations dist/migrations && npm run build --prefix client",
    "build:server": "tsc && cp -r src/migrations dist/migrations",
    "start": "node dist/index.js",
    "start:production": "NODE_ENV=production node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && npm run typecheck --prefix client",
    "test": "vitest run && npm test --prefix client",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
